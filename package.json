{
  "name": "study-buddy-agent",
  "version": "1.0.0",
  "description": "A JavaScript AI agent that turns raw study notes into validated flashcards.",
  "type": "module",
  "private": true,
  "bin": {
    "study-buddy": "./src/cli.js"
  },
  "scripts": {
    "start": "node src/cli.js",
    "web": "node src/server.js",
    "deploy": "vercel --prod",
    "demo": "node src/cli.js --file examples/technical-notes.md --mock --json-out examples/technical-output.json --md-out examples/technical-output.md",
    "test": "node --test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.61.0",
    "pdf-parse": "^2.4.5"
  },
  "engines": {
    "node": "20.x"
  }
}
